const formStatus = {
  aboutSelfForm: false,
  incomeDetailsForm: false,
  anotherDetailsForm: false,
  deductionForm: false,
};

function showForm(formId) {
  document.getElementById("aboutSelfForm").style.display = "none";
  document.getElementById("incomeDetailsForm").style.display = "none";
  document.getElementById("anotherDetailsForm").style.display = "none";
  document.getElementById("deductionForm").style.display = "none";

  document.getElementById(formId).style.display = "block";
  updateFormStatus(formId);
}

function updateFormStatus(formId) {
  formStatus[formId] = true;
  for (const key in formStatus) {
    const statusElement = document.getElementById(key + "Status");
    const progressElement = document.getElementById(key + "Progress");
    if (statusElement) {
      statusElement.innerText = formStatus[key] ? "Done" : "";
    }
    if (progressElement) {
      progressElement.style.width = formStatus[key] ? "100%" : "0%";
    }
  }
}

