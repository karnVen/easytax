(function ($) {
  "use strict";

  //Hide Loading Box (Preloader)
  function handlePreloader() {
    if ($(".preloader").length) {
      $(".preloader").delay(200).fadeOut(500);
    }
  }

  // Get the popup container and close button elements
  const popupContainer = document.querySelector("#block-techprosolutions-limitedtimeoffer");
  const closeButton = document.querySelector(".close-btn");

  // Get the countdown timer elements
  const daysElement = document.getElementById("days");
  const hoursElement = document.getElementById("hours");
  const minutesElement = document.getElementById("minutes");
  const secondsElement = document.getElementById("seconds");

  // Set the countdown timer duration (in seconds)
  const countdownDuration = 10 * 24 * 60 * 60; // 10 days

  // Set the countdown timer start time
  const startTime = new Date().getTime() + countdownDuration * 1000;

  // Function to update the countdown timer
  function updateCountdown() {
    const currentTime = new Date().getTime();
    const timeRemaining = startTime - currentTime;

    // Calculate the days, hours, minutes, and seconds remaining
    const days = Math.floor(timeRemaining / (1000 * 60 * 60 * 24));
    const hours = Math.floor(
      (timeRemaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)
    );
    const minutes = Math.floor(
      (timeRemaining % (1000 * 60 * 60)) / (1000 * 60)
    );
    const seconds = Math.floor((timeRemaining % (1000 * 60)) / 1000);

    // Update the countdown timer elements
    daysElement.textContent = days.toString().padStart(2, "0");
    hoursElement.textContent = hours.toString().padStart(2, "0");
    minutesElement.textContent = minutes.toString().padStart(2, "0");
    secondsElement.textContent = seconds.toString().padStart(2, "0");

    // Check if the countdown timer has expired
    if (timeRemaining <= 0) {
      // Hide the popup container
      popupContainer.style.display = "none";
    }
  }

  // Function to show the popup container
  function showPopup() {
    // Show the popup container
    popupContainer.style.display = "flex";

    // Start the countdown timer
    setInterval(updateCountdown, 1000);
  }

  // Add event listener to the close button
  closeButton.addEventListener("click", () => {
    // Hide the popup container
    popupContainer.style.display = "none";
  });

  // Show the popup container after 2 seconds
  setTimeout(showPopup, 2000);

  //Update Header Style and Scroll to Top
  function headerStyle() {
    if ($(".main-header").length) {
      var windowpos = $(window).scrollTop();
      var siteHeader = $(".main-header");
      var scrollLink = $(".scroll-top");
      if (windowpos >= 110) {
        siteHeader.addClass("fixed-header");
        scrollLink.addClass("open");
      } else {
        siteHeader.removeClass("fixed-header");
        scrollLink.removeClass("open");
      }
    }
